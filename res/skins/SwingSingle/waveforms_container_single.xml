<!--
Description:
  Container for one stacked scrolling waveform.
-->
<Template>
  <WidgetGroup>
    <ObjectName>WaveformContainer</ObjectName>
    <Layout>horizontal</Layout>
    <SizePolicy>me,min</SizePolicy>
    <Children>
      <Template src="skins:Swing/controls/button_2state_persist.xml">
        <SetVariable name="ObjectName">StemButtonToggler</SetVariable>
        <SetVariable name="TooltipId">show_stem_controls</SetVariable>
        <SetVariable name="Size">14f,22me</SetVariable>
        <SetVariable name="ConfigKey">[Skin],show_stem_controls</SetVariable>
      </Template>

      <WidgetGroup><ObjectName>Spacer0f</ObjectName><Size>1f,1me</Size></WidgetGroup>

      <WidgetGroup>
        <Layout>vertical</Layout>
        <SizePolicy>me,min</SizePolicy>
        <Children>
          <Template src="skins:Swing/waveform.xml">
            <SetVariable name="chanNum">1</SetVariable>
            <SetVariable name="SignalBgColor"><Variable name="SignalBgColor_12"/></SetVariable>
            <SetVariable name="SignalColor"><Variable name="SignalColor_12"/></SetVariable>
          </Template>
        </Children>
      </WidgetGroup>

      <WidgetGroup><ObjectName>Spacer0f</ObjectName><Size>1f,1me</Size></WidgetGroup>

      <Template src="skins:Swing/controls/button_2state_persist.xml">
        <SetVariable name="ObjectName">BeatgridButtonToggler</SetVariable>
        <SetVariable name="Size">14f,22me</SetVariable>
        <SetVariable name="ConfigKey">[Swing],beatgrid_buttons</SetVariable>
      </Template>
    </Children>
  </WidgetGroup>
</Template>
