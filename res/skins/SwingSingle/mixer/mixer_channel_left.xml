<!--
Description:
  Single-deck channel mixer for SwingSingle.
  EQ controls are shown as a horizontal row of vertical faders
  with labels underneath each element.
Variables:
  group : [ChannelXY]
-->
<Template>
  <WidgetGroup>
    <ObjectName>MixerChannelLeft</ObjectName>
    <Layout>horizontal</Layout>
    <Size>-1max,136f</Size>
    <Children>
      <WidgetGroup><ObjectName>Spacer0f</ObjectName><Size>1f,1min</Size></WidgetGroup>

      <WidgetGroup><Size>2f,1min</Size></WidgetGroup>
      <!-- Volumes + VU + EQ -->
      <WidgetGroup>
        <Layout>vertical</Layout>
        <SizePolicy>max,min</SizePolicy>
        <Children>

          <WidgetGroup><!-- Volumes + VU + EQ row -->
            <Layout>horizontal</Layout>
            <SizePolicy>max,me</SizePolicy>
            <Children>

              <WidgetGroup><!-- Main volume + gain + headphone volume -->
                <ObjectName>VolumeSliderGain</ObjectName>
                <Layout>horizontal</Layout>
                <SizePolicy>f,me</SizePolicy>
                <Children>
                  <WidgetGroup><!-- Main volume slider + gain knob -->
                    <Layout>vertical</Layout>
                    <SizePolicy>f,me</SizePolicy>
                    <Children>
                      <SliderComposed><!-- Main volume slider -->
                        <Size>34f,89min</Size>
                        <ObjectName>VolumeSlider</ObjectName>
                        <TooltipId>channel_volume</TooltipId>
                        <Slider scalemode="STRETCH">skins:Swing/knobs_sliders/volume_scale.svg</Slider>
                        <Handle scalemode="STRETCH_ASPECT">skins:Swing/knobs_sliders/volume_handle.svg</Handle>
                        <Horizontal>false</Horizontal>
                        <Connection>
                          <ConfigKey><Variable name="group"/>,volume</ConfigKey>
                        </Connection>
                      </SliderComposed><!-- /Main volume slider -->

                      <!-- Gain knob, centered below Main volume slider -->
                      <Template src="skins:Swing/controls/knob_textless.xml">
                        <SetVariable name="ObjectName">GainKnob</SetVariable>
                        <SetVariable name="TooltipId">pregain</SetVariable>
                        <SetVariable name="Size">34f,30f</SetVariable>
                        <SetVariable name="Color">yellow</SetVariable>
                        <SetVariable name="group"><Variable name="group"/></SetVariable>
                        <SetVariable name="ConfigKey">pregain</SetVariable>
                      </Template>

                      <Label>
                        <Size>34f,14f</Size>
                        <Text>MAIN</Text>
                        <Alignment>center</Alignment>
                      </Label>
                    </Children>
                  </WidgetGroup><!-- /Main volume slider + gain knob -->

                  <WidgetGroup><Size>8f,1min</Size></WidgetGroup>

                  <WidgetGroup><!-- VU Meter -->
                    <ObjectName>AlignCenter</ObjectName>
                    <Layout>vertical</Layout>
                    <Children>
                      <Template src="skins:Swing/mixer/vumeter_mixer.xml"/>
                    </Children>
                  </WidgetGroup><!-- /VU Meter -->

                  <WidgetGroup><Size>8f,1min</Size></WidgetGroup>

                  <WidgetGroup><!-- Headphone volume slider -->
                    <Layout>vertical</Layout>
                    <SizePolicy>f,me</SizePolicy>
                    <Children>
                      <SliderComposed>
                        <Size>34f,1me</Size>
                        <ObjectName>HeadphoneVolumeSlider</ObjectName>
                        <TooltipId>headphone_volume</TooltipId>
                        <Slider scalemode="STRETCH">skins:Swing/knobs_sliders/volume_scale.svg</Slider>
                        <Handle scalemode="STRETCH_ASPECT">skins:Swing/knobs_sliders/volume_handle.svg</Handle>
                        <Horizontal>false</Horizontal>
                        <Connection>
                          <ConfigKey>[Master],headGain</ConfigKey>
                        </Connection>
                      </SliderComposed>

                      <WidgetGroup>
                        <ObjectName>HeadphoneMixerLabel</ObjectName>
                        <Size>34f,14f</Size>
                      </WidgetGroup>
                    </Children>
                  </WidgetGroup><!-- /Headphone volume slider -->
                </Children>
              </WidgetGroup><!-- /Main volume + gain + headphone volume -->

              <WidgetGroup><Size>8f,1min</Size></WidgetGroup>

              <WidgetGroup><!-- EQ faders with labels -->
                <Layout>vertical</Layout>
                <SizePolicy>max,me</SizePolicy>
                <Children>

                  <WidgetGroup>
                    <ObjectName>EqSliderRow</ObjectName>
                    <Layout>horizontal</Layout>
                    <SizePolicy>max,me</SizePolicy>
                    <Children>
                      <WidgetGroup>
                        <Layout>vertical</Layout>
                        <SizePolicy>min,me</SizePolicy>
                        <Children>
                          <SliderComposed>
                            <Size>34f,1me</Size>
                            <ObjectName>EqSliderLow</ObjectName>
                            <Slider scalemode="STRETCH">skins:Swing/knobs_sliders/volume_scale.svg</Slider>
                            <Handle scalemode="STRETCH_ASPECT">skins:SwingSingle/knobs_sliders/volume_handle_eq_low.svg</Handle>
                            <Horizontal>false</Horizontal>
                            <Connection>
                              <ConfigKey>[EqualizerRack1_<Variable name="group"/>_Effect1],parameter1</ConfigKey>
                            </Connection>
                          </SliderComposed>
                          <Label>
                            <Size>34f,14f</Size>
                            <Text>LOW</Text>
                            <Alignment>center</Alignment>
                          </Label>
                        </Children>
                      </WidgetGroup>

                      <WidgetGroup><Size>8f,1min</Size></WidgetGroup>

                      <WidgetGroup>
                        <Layout>vertical</Layout>
                        <SizePolicy>min,me</SizePolicy>
                        <Children>
                          <SliderComposed>
                            <Size>34f,1me</Size>
                            <ObjectName>EqSliderMid</ObjectName>
                            <Slider scalemode="STRETCH">skins:Swing/knobs_sliders/volume_scale.svg</Slider>
                            <Handle scalemode="STRETCH_ASPECT">skins:SwingSingle/knobs_sliders/volume_handle_eq_mid.svg</Handle>
                            <Horizontal>false</Horizontal>
                            <Connection>
                              <ConfigKey>[EqualizerRack1_<Variable name="group"/>_Effect1],parameter2</ConfigKey>
                            </Connection>
                          </SliderComposed>
                          <Label>
                            <Size>34f,14f</Size>
                            <Text>MID</Text>
                            <Alignment>center</Alignment>
                          </Label>
                        </Children>
                      </WidgetGroup>

                      <WidgetGroup><Size>8f,1min</Size></WidgetGroup>

                      <WidgetGroup>
                        <Layout>vertical</Layout>
                        <SizePolicy>min,me</SizePolicy>
                        <Children>
                          <SliderComposed>
                            <Size>34f,1me</Size>
                            <ObjectName>EqSliderHigh</ObjectName>
                            <Slider scalemode="STRETCH">skins:Swing/knobs_sliders/volume_scale.svg</Slider>
                            <Handle scalemode="STRETCH_ASPECT">skins:SwingSingle/knobs_sliders/volume_handle_eq_high.svg</Handle>
                            <Horizontal>false</Horizontal>
                            <Connection>
                              <ConfigKey>[EqualizerRack1_<Variable name="group"/>_Effect1],parameter3</ConfigKey>
                            </Connection>
                          </SliderComposed>
                          <Label>
                            <Size>34f,14f</Size>
                            <Text>HIGH</Text>
                            <Alignment>center</Alignment>
                          </Label>
                        </Children>
                      </WidgetGroup>

                      <WidgetGroup><Size>8f,1min</Size></WidgetGroup>

                      <WidgetGroup>
                        <ObjectName>SpectrumSection</ObjectName>
                        <Layout>vertical</Layout>
                        <SizePolicy>min,me</SizePolicy>
                        <Children>
                          <Spectrum>
                            <ObjectName>SpectrumDisplay</ObjectName>
                            <Group><Variable name="group"/></Group>
                            <Size>120f,1me</Size>
                            <NumberOfBins>64</NumberOfBins>
                            <BarGap>1</BarGap>
                            <DecayPerTick>6</DecayPerTick>
                            <ShowFilteredLine>true</ShowFilteredLine>
                            <FilteredLineLowPass>35</FilteredLineLowPass>
                          </Spectrum>
                          <Label>
                            <Size>120f,14f</Size>
                            <Text>SPEC</Text>
                            <Alignment>center</Alignment>
                          </Label>
                        </Children>
                      </WidgetGroup>

                    </Children>
                    <Connection>
                      <ConfigKey>[EqualizerRack1_<Variable name="group"/>_Effect1],loaded</ConfigKey>
                      <BindProperty>visible</BindProperty>
                    </Connection>
                  </WidgetGroup>

                </Children>
                <Connection>
                  <ConfigKey persist="true">[Skin],show_eq_knobs</ConfigKey>
                  <BindProperty>visible</BindProperty>
                </Connection>
              </WidgetGroup><!-- /EQ faders with labels -->

            </Children>
          </WidgetGroup><!-- /Volumes + VU + EQ row -->


        </Children>
      </WidgetGroup><!-- /Volumes + VU + EQ -->

    </Children>
  </WidgetGroup>
</Template>
